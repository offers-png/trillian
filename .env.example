# ─────────────────────────────────────────────────────────────
# TRILLIAN — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── AI BRAIN ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # console.anthropic.com → API Keys

# ── VOICE: ElevenLabs ─────────────────────────────────────────
# 1. Go to elevenlabs.io → Voices → search "British"
# 2. Pick a voice → copy the Voice ID from the URL or voice card
# 3. Profile → API Keys → create a key
ELEVENLABS_API_KEY=                    # elevenlabs.io/profile → API Keys
ELEVENLABS_VOICE_ID=                  # e.g. EXAVITQu4vr4xnSDxMaL (Charlotte)
ELEVENLABS_MODEL=eleven_turbo_v2      # eleven_turbo_v2 (fast) or eleven_multilingual_v2 (quality)

# ── VOICE: Speech-to-Text ─────────────────────────────────────
DEEPGRAM_API_KEY=                     # deepgram.com → Console → API Keys
# OR use local Whisper (set STT_PROVIDER=whisper, no API key needed)
STT_PROVIDER=deepgram                 # deepgram | whisper

# ── MEMORY: Supabase ──────────────────────────────────────────
SUPABASE_URL=https://wzcuzyouymauokijaqjk.supabase.co
SUPABASE_ANON_KEY=                    # Supabase → Settings → API → anon key
SUPABASE_SERVICE_ROLE_KEY=            # Supabase → Settings → API → service_role key (keep secret)

# ── EMBEDDINGS (for semantic memory search) ───────────────────
OPENAI_API_KEY=                       # platform.openai.com → API Keys (for text-embedding-3-small)

# ── INTEGRATIONS: Google ──────────────────────────────────────
# console.cloud.google.com → Create project → Enable Calendar API + Gmail API
# → Credentials → OAuth 2.0 Client → Desktop app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── INTEGRATIONS: Stripe ──────────────────────────────────────
STRIPE_SECRET_KEY=                    # dashboard.stripe.com → Developers → API Keys → Secret key
# NOTE: Trillian uses read-only operations only by default

# ── INTEGRATIONS: n8n ─────────────────────────────────────────
N8N_URL=https://saleh852.app.n8n.cloud
N8N_API_KEY=                          # n8n → Settings → API → create key

# ── INTEGRATIONS: Twilio (for SMS fallback) ───────────────────
TWILIO_SID=                           # console.twilio.com → Account SID
TWILIO_AUTH_TOKEN=                    # console.twilio.com → Auth Token
TWILIO_FROM=                          # Your Twilio phone number e.g. +13156252025

# ── LOCAL FILESYSTEM SANDBOX ──────────────────────────────────
# Trillian can only read/write within this directory
TRILLIAN_ROOT_DIR=/Users/yourname/Documents/Trillian

# ── WAKE WORD ─────────────────────────────────────────────────
WAKE_WORD=hey trillian               # The phrase that activates Trillian
WAKE_WORD_SENSITIVITY=0.7            # 0.0 (permissive) to 1.0 (strict)

# ── SERVER CONFIG ─────────────────────────────────────────────
PORT=4000                             # Core server port
NODE_ENV=development                  # development | production

# ── BRIEFING SCHEDULE ─────────────────────────────────────────
MORNING_BRIEFING_TIME=08:00           # Time for automatic morning briefing (24hr)
BRIEFING_TIMEZONE=America/New_York
